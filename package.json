    "minimap",
    "outline"
  ],
  "author": "f42",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.7.2",
    "typescript": "^5.7.2"
  }
}
