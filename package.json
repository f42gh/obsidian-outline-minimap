  "description": "A lightweight Obsidian minimap that navigates Markdown headings.",
  "main": "main.js",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
